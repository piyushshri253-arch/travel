generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ////////////////////
/// ////////////////////
model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  points    Int       @default(0)
  createdAt DateTime  @default(now())
  bookings  Booking[]
  reviews   Review[]

  @@index([email])
}

/// ////////////////////
/// ////////////////////
model Booking {
  id           String   @id @default(uuid())
  destination  String
  price        Int
  pointsEarned Int
  userId       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// ////////////////////
/// ////////////////////
model Review {
  id          String   @id @default(uuid())
  name        String
  email       String
  rating      Int
  comment     String
  destination String?
  avatar      String?
  date        DateTime @default(now())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

/// ////////////////////
/// ////////////////////
model Trip {
  id           String        @id @default(uuid())
  slug         String        @unique
  category     String
  title        String
  duration     String
  price        String
  pickupDrop   String?
  routeLine    String?
  overview     String
  banner       String[]
  images       String[]
  createdAt    DateTime      @default(now())
  exclusions   String[]
  inclusions   String[]
  otherInfo    String[]
  itinerary    Itinerary[]
  similarTrips SimilarTrip[]

  @@index([category])
  @@index([slug])
}

/// ////////////////////
/// ////////////////////
model Itinerary {
  id          String @id @default(uuid())
  title       String
  description String
  tripId      String
  trip        Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

/// ////////////////////
/// ////////////////////
model SimilarTrip {
  id       String @id @default(uuid())
  title    String
  price    String
  duration String
  location String
  date     String
  batch    String
  image    String
  slug     String
  tripId   String
  trip     Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
}
